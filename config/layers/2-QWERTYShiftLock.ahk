; ====================================== ADDITIONAL KEYS ======================================
CapsLock::{
    SendInput("{Esc}")
    toggleLayer("Vim")
}

RAlt::{
    SendInput("{RControl down}")
    if(KeyWait(ThisHotkey, "T.18")){
        KeyWait(ThisHotkey)
        SendInput("{RControl up}")
        if(ThisHotkey = A_ThisHotkey){
            toggleLayer("Numpad")
        }
    } else {
        KeyWait(ThisHotkey)
        SendInput("{RControl up}")
    }
}

Shift::{
    SendInput("{Shift down}")
    if(KeyWait(ThisHotkey, "T.18")){
        KeyWait(ThisHotkey)
        SendInput("{Shift up}")
        if(ThisHotkey = A_ThisHotkey){
            toggleLayer("Qwerty")
        }
    } else {
        KeyWait(ThisHotkey)
        SendInput("{Shift up}")
    }
}
